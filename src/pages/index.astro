---
// SiteForge World Clock — internal caller tool
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SiteForge · Caller Dashboard</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --brand:        #3B82F6;
      --brand-dark:   #2563EB;
      --brand-cyan:   #06B6D4;
      --ink:          #0A0F1E;
      --dark-card:    #111827;
      --dark-border:  rgba(255,255,255,0.08);
      --green:        #22c55e;
      --green-bg:     rgba(34,197,94,0.12);
      --green-border: rgba(34,197,94,0.25);
      --red:          #ef4444;
      --red-bg:       rgba(239,68,68,0.12);
      --red-border:   rgba(239,68,68,0.25);
      --amber:        #f59e0b;
      --amber-bg:     rgba(245,158,11,0.12);
      --amber-border: rgba(245,158,11,0.25);
    }

    html { font-size: 18px; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--ink);
      color: #fff;
      min-height: 100vh;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      opacity: 0.35;
      z-index: 0;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0.75rem 1rem;
    }

    .nav-pill {
      max-width: 1100px;
      margin: 0 auto;
      background: rgba(10,15,30,0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--dark-border);
      border-radius: 16px;
      padding: 0 1.5rem;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
    }

    .logo-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--brand), var(--brand-cyan));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .logo-icon span {
      font-family: 'Manrope', sans-serif;
      font-weight: 800;
      font-size: 15px;
      color: #fff;
    }

    .logo-text {
      font-family: 'Manrope', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: #fff;
      letter-spacing: 0.02em;
    }

    .nav-badge {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      color: rgba(255,255,255,0.35);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ── HERO ── */
    .hero-strip {
      position: relative;
      z-index: 1;
      padding: 3rem 1rem 0;
      overflow: hidden;
    }

    .hero-strip::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 80% at 15% 50%, rgba(59,130,246,0.18) 0%, transparent 65%),
        radial-gradient(ellipse 50% 60% at 85% 10%, rgba(6,182,212,0.1) 0%, transparent 60%),
        radial-gradient(ellipse 55% 55% at 80% 85%, rgba(59,130,246,0.07) 0%, transparent 60%);
      pointer-events: none;
    }

    .hero-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 2rem;
      position: relative;
      padding-bottom: 2.5rem;
    }

    .hero-city { display: flex; flex-direction: column; gap: 0.35rem; }
    .hero-city.right { text-align: right; align-items: flex-end; }

    .city-label {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--brand);
    }

    .city-name {
      font-family: 'Manrope', sans-serif;
      font-size: 1.3rem;
      font-weight: 600;
      color: rgba(255,255,255,0.5);
    }

    .city-time {
      font-family: 'Manrope', sans-serif;
      font-size: clamp(3rem, 5.5vw, 5rem);
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .city-date {
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      color: rgba(255,255,255,0.3);
      margin-top: 0.2rem;
    }

    .hero-divider {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .divider-line {
      width: 1px;
      height: 52px;
      background: linear-gradient(to bottom, transparent, rgba(59,130,246,0.45), transparent);
    }

    .divider-globe {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: rgba(59,130,246,0.12);
      border: 1px solid rgba(59,130,246,0.28);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
    }

    .hero-border-wrap {
      max-width: 1100px;
      margin: 0 auto;
    }

    .hero-shimmer {
      height: 1px;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(59,130,246,0.35) 25%,
        rgba(6,182,212,0.55) 50%,
        rgba(59,130,246,0.35) 75%,
        transparent 100%);
    }

    /* ── MAIN ── */
    main {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 2.5rem 1rem 4rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .section-title {
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .live-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--brand);
      flex-shrink: 0;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: 0.4; transform: scale(0.7); }
    }

    .section-line {
      flex: 1;
      height: 1px;
      background: var(--dark-border);
    }

    /* ── TZ GRID ── */
    .tz-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--dark-border);
      border: 1px solid var(--dark-border);
      border-radius: 16px;
      overflow: hidden;
    }

    .tz-card {
      background: var(--dark-card);
      padding: 1.5rem 1.5rem 2.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      position: relative;
      transition: background 0.2s;
    }

    .tz-card:hover { background: #13192e; }

    .tz-card.open    { background: rgba(17,24,39,0.98); box-shadow: inset 0 2px 0 var(--green); }
    .tz-card.closed  { background: rgba(17,24,39,0.98); box-shadow: inset 0 2px 0 var(--red); }
    .tz-card.warning { background: rgba(17,24,39,0.98); box-shadow: inset 0 2px 0 var(--amber); }

    .tz-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.4rem;
    }

    .tz-name {
      font-family: 'Manrope', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .no-dst-tag {
      font-family: 'Inter', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.28);
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
    }

    .tz-status {
      font-family: 'Inter', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.25rem 0.65rem;
      border-radius: 5px;
    }

    .status-open    { background: var(--green-bg);  color: var(--green);  border: 1px solid var(--green-border); }
    .status-closed  { background: var(--red-bg);    color: var(--red);    border: 1px solid var(--red-border); }
    .status-warning { background: var(--amber-bg);  color: var(--amber);  border: 1px solid var(--amber-border); }

    .tz-time {
      font-family: 'Manrope', sans-serif;
      font-size: clamp(2rem, 3vw, 3rem);
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .tz-date {
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      font-weight: 400;
      color: rgba(255,255,255,0.35);
      margin-bottom: 0.3rem;
    }

    .tz-states {
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      font-weight: 400;
      color: rgba(255,255,255,0.55);
      line-height: 1.85;
    }

    .tz-partly {
      display: block;
      margin-top: 0.3rem;
      font-size: 0.8rem;
      color: rgba(255,255,255,0.3);
      font-style: italic;
    }

    .tz-offset {
      position: absolute;
      bottom: 0.85rem;
      right: 1.25rem;
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      font-weight: 500;
      color: rgba(255,255,255,0.25);
      letter-spacing: 0.04em;
    }

    /* ── FOOTER ── */
    footer {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 1.5rem 1rem 2rem;
      border-top: 1px solid var(--dark-border);
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 400;
      color: rgba(255,255,255,0.2);
      letter-spacing: 0.08em;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .tz-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 580px) {
      .tz-grid { grid-template-columns: 1fr; }
      .hero-inner { grid-template-columns: 1fr; gap: 2rem; padding-bottom: 2rem; }
      .hero-city.right { text-align: left; align-items: flex-start; }
      .hero-divider { display: none; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-pill">
      <a href="/" class="logo">
        <div class="logo-icon"><span>S</span></div>
        <span class="logo-text">SiteForge</span>
      </a>
      <span class="nav-badge">Caller Dashboard</span>
    </div>
  </nav>

  <!-- HERO -->
  <div class="hero-strip">
    <div class="hero-inner">
      <div class="hero-city left">
        <span class="city-label">Home Base</span>
        <span class="city-name">Central Europe</span>
        <div class="city-time" id="lj-time">--:--</div>
        <div class="city-date" id="lj-date">---</div>
      </div>

      <div class="hero-divider">
        <div class="divider-line"></div>
        <div class="divider-globe">🌐</div>
        <div class="divider-line"></div>
      </div>

      <div class="hero-city right">
        <span class="city-label">Caller Team</span>
        <span class="city-name">Manila, Philippines</span>
        <div class="city-time" id="mn-time">--:--</div>
        <div class="city-date" id="mn-date">---</div>
      </div>
    </div>
    <div class="hero-border-wrap">
      <div class="hero-shimmer"></div>
    </div>
  </div>

  <!-- US TIMEZONES -->
  <main>
    <div class="section-header">
      <span class="section-title">
        <span class="live-dot"></span>
        US Time Zones
      </span>
      <div class="section-line"></div>
    </div>

    <div class="tz-grid">

      <div class="tz-card" id="card-eastern">
        <div class="tz-top">
          <span class="tz-name">Eastern</span>
          <span class="tz-status" id="status-eastern">—</span>
        </div>
        <div class="tz-time" id="time-eastern">--:--</div>
        <div class="tz-date" id="date-eastern">---</div>
        <div class="tz-states">
          Most of the East Coast and Southeast.<br>
          Connecticut · Delaware · Georgia · Maine · Maryland ·
          Massachusetts · New Hampshire · New Jersey · New York ·
          North Carolina · Ohio · Pennsylvania · Rhode Island ·
          South Carolina · Vermont · Virginia · Washington D.C. ·
          West Virginia<br>
          <span class="tz-partly">Partly: Florida · Indiana · Kentucky · Michigan · Tennessee</span>
        </div>
        <span class="tz-offset">UTC−5/−4</span>
      </div>

      <div class="tz-card" id="card-central">
        <div class="tz-top">
          <span class="tz-name">Central</span>
          <span class="tz-status" id="status-central">—</span>
        </div>
        <div class="tz-time" id="time-central">--:--</div>
        <div class="tz-date" id="date-central">---</div>
        <div class="tz-states">
          Most of the Midwest and South.<br>
          Alabama · Arkansas · Illinois · Iowa · Louisiana ·
          Minnesota · Mississippi · Missouri · Oklahoma · Wisconsin<br>
          <span class="tz-partly">Partly: Indiana · Kansas · Kentucky · Michigan · Nebraska ·
          North Dakota · South Dakota · Tennessee · Texas</span>
        </div>
        <span class="tz-offset">UTC−6/−5</span>
      </div>

      <div class="tz-card" id="card-mountain">
        <div class="tz-top">
          <span class="tz-name">Mountain</span>
          <span class="tz-status" id="status-mountain">—</span>
        </div>
        <div class="tz-time" id="time-mountain">--:--</div>
        <div class="tz-date" id="date-mountain">---</div>
        <div class="tz-states">
          Mountain states and selected western counties.<br>
          Colorado · Montana · New Mexico · Utah · Wyoming<br>
          <span class="tz-partly">Partly: Idaho · Kansas · Nebraska · North Dakota ·
          Oregon · South Dakota · Texas</span>
        </div>
        <span class="tz-offset">UTC−7/−6</span>
      </div>

      <div class="tz-card" id="card-arizona">
        <div class="tz-top">
          <span class="tz-name">Arizona <span class="no-dst-tag">NO DST</span></span>
          <span class="tz-status" id="status-arizona">—</span>
        </div>
        <div class="tz-time" id="time-arizona">--:--</div>
        <div class="tz-date" id="date-arizona">---</div>
        <div class="tz-states">
          Arizona · No daylight saving time · Always UTC−7 year-round
        </div>
        <span class="tz-offset">UTC−7</span>
      </div>

      <div class="tz-card" id="card-pacific">
        <div class="tz-top">
          <span class="tz-name">Pacific</span>
          <span class="tz-status" id="status-pacific">—</span>
        </div>
        <div class="tz-time" id="time-pacific">--:--</div>
        <div class="tz-date" id="date-pacific">---</div>
        <div class="tz-states">
          West Coast and Pacific states.<br>
          California · Nevada · Washington · Oregon (most)<br>
          <span class="tz-partly">Partly: Idaho (north)</span>
        </div>
        <span class="tz-offset">UTC−8/−7</span>
      </div>

      <div class="tz-card" id="card-alaska">
        <div class="tz-top">
          <span class="tz-name">Alaska</span>
          <span class="tz-status" id="status-alaska">—</span>
        </div>
        <div class="tz-time" id="time-alaska">--:--</div>
        <div class="tz-date" id="date-alaska">---</div>
        <div class="tz-states">
          Alaska (most of the state) · 4 hours behind Eastern (during DST)
        </div>
        <span class="tz-offset">UTC−9/−8</span>
      </div>

      <div class="tz-card" id="card-hawaii">
        <div class="tz-top">
          <span class="tz-name">Hawaii <span class="no-dst-tag">NO DST</span></span>
          <span class="tz-status" id="status-hawaii">—</span>
        </div>
        <div class="tz-time" id="time-hawaii">--:--</div>
        <div class="tz-date" id="date-hawaii">---</div>
        <div class="tz-states">
          Hawaii · No daylight saving time · Always UTC−10 year-round
        </div>
        <span class="tz-offset">UTC−10</span>
      </div>

    </div>
  </main>

  <footer>SITEFORGE · INTERNAL USE ONLY</footer>

  <script>
    function getCallStatus(h, m) {
      const t = h * 60 + m;
      if (t < 480 || t >= 1260) return 'closed';
      if (t >= 1230) return 'warning';
      return 'open';
    }

    const labels = { open: 'CALL NOW', warning: 'CLOSING SOON', closed: 'DO NOT CALL' };

    function fmt24(date, tz) {
      return new Intl.DateTimeFormat('en-GB', {
        timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: false
      }).format(date);
    }

    function fmtDate(date, tz) {
      return new Intl.DateTimeFormat('en-US', {
        timeZone: tz, weekday: 'short', month: 'short', day: 'numeric'
      }).format(date);
    }

    function getHM(date, tz) {
      const p = new Intl.DateTimeFormat('en-US', {
        timeZone: tz, hour: 'numeric', minute: '2-digit', hour12: false
      }).formatToParts(date);
      return {
        h: parseInt(p.find(x => x.type === 'hour')?.value ?? '0'),
        m: parseInt(p.find(x => x.type === 'minute')?.value ?? '0')
      };
    }

    const zones = [
      { id: 'eastern',  tz: 'America/New_York' },
      { id: 'central',  tz: 'America/Chicago' },
      { id: 'mountain', tz: 'America/Denver' },
      { id: 'arizona',  tz: 'America/Phoenix' },
      { id: 'pacific',  tz: 'America/Los_Angeles' },
      { id: 'alaska',   tz: 'America/Anchorage' },
      { id: 'hawaii',   tz: 'Pacific/Honolulu' },
    ];

    function tick() {
      const now = new Date();
      document.getElementById('lj-time').textContent = fmt24(now, 'Europe/Ljubljana');
      document.getElementById('lj-date').textContent = fmtDate(now, 'Europe/Ljubljana');
      document.getElementById('mn-time').textContent = fmt24(now, 'Asia/Manila');
      document.getElementById('mn-date').textContent = fmtDate(now, 'Asia/Manila');

      for (const { id, tz } of zones) {
        const { h, m } = getHM(now, tz);
        const s = getCallStatus(h, m);
        document.getElementById(`time-${id}`).textContent = fmt24(now, tz);
        document.getElementById(`date-${id}`).textContent = fmtDate(now, tz);
        const sEl = document.getElementById(`status-${id}`);
        sEl.textContent = labels[s];
        sEl.className = `tz-status status-${s}`;
        document.getElementById(`card-${id}`).className = `tz-card ${s}`;
      }
    }

    tick();
    setInterval(tick, 1000);
  </script>

</body>
</html>
